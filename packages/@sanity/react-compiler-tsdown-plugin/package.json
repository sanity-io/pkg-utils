{
  "name": "@sanity/react-compiler-tsdown-plugin",
  "version": "0.0.0",
  "description": "tsdown plugin that opts allow-listed Sanity API surfaces (defineConfig/defineType components, PortableText component maps) into React Compiler memoization with 'use memo' directives",
  "keywords": [
    "sanity-io",
    "sanity",
    "react-compiler",
    "react",
    "tsdown",
    "rolldown",
    "memoization",
    "plugin"
  ],
  "homepage": "https://github.com/sanity-io/pkg-utils/tree/main/packages/@sanity/react-compiler-tsdown-plugin#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/pkg-utils/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/pkg-utils.git",
    "directory": "packages/@sanity/react-compiler-tsdown-plugin"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@sanity/react-compiler-rolldown-plugin": "workspace:^"
  },
  "devDependencies": {
    "@sanity/tsconfig": "workspace:^",
    "@sanity/tsdown-config": "workspace:^",
    "@types/node": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "tsdown": "^0.22.5"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
