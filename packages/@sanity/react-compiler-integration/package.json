{
  "name": "@sanity/react-compiler-integration",
  "version": "0.0.0",
  "description": "Injects 'use memo' React Compiler opt-in directives into allow-listed Sanity API surfaces (defineConfig/defineType components, PortableText component maps), so object-property components and hooks the compiler's infer mode never sees get memoized",
  "keywords": [
    "sanity-io",
    "sanity",
    "react-compiler",
    "react",
    "memoization",
    "yuku",
    "oxc"
  ],
  "homepage": "https://github.com/sanity-io/pkg-utils/tree/main/packages/@sanity/react-compiler-integration#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/pkg-utils/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/pkg-utils.git",
    "directory": "packages/@sanity/react-compiler-integration"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "yuku-parser": "^0.6.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@sanity/tsconfig": "workspace:^",
    "@sanity/tsdown-config": "workspace:^",
    "@types/babel__core": "^7.20.5",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "babel-plugin-react-compiler": "^1.0.0",
    "publint": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
