    "vitest": "catalog:"
  },
  "peerDependencies": {
    "rolldown": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
