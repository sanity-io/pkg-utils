{
  "name": "sanity-css-vanilla-extract-test",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bundle.css": {
      "types": "./dist/bundle-css.d.ts",
      "browser": "./dist/bundle.css",
      "style": "./dist/bundle.css",
      "node": "./dist/bundle-css.js",
      "default": "./dist/bundle-css.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pkg build --strict --check --clean",
    "clean": "rimraf dist",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@sanity/pkg-utils": "workspace:*",
    "@sanity/tsconfig": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.21.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "sanity-css-vanilla-extract-test": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./bundle.css": {
        "types": "./dist/bundle-css.d.ts",
        "browser": "./dist/bundle.css",
        "style": "./dist/bundle.css",
        "node": "./dist/bundle-css.js",
        "default": "./dist/bundle-css.js"
      },
      "./package.json": "./package.json"
    }
  }
}
