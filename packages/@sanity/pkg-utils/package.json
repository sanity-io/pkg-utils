{
  "name": "@sanity/pkg-utils",
  "version": "11.0.14",
  "description": "Simple utilities for modern npm packages.",
  "keywords": [
    "sanity-io",
    "sanity",
    "npm",
    "package",
    "utilities",
    "build",
    "bundling"
  ],
  "homepage": "https://github.com/sanity-io/pkg-utils#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/pkg-utils/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/pkg-utils.git",
    "directory": "packages/@sanity/pkg-utils"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/node/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pkg": "./bin/pkg-utils.js",
    "pkg-utils": "./bin/pkg-utils.js"
  },
  "files": [
    "bin",
    "dist",
    "tsconfig",
    "!dist/stats.html"
  ],
  "scripts": {
    "build": "run-s clean build:pkg check:pkg",
    "build:pkg": "tsx scripts/build.ts",
    "check:pkg": "tsx scripts/check.ts",
    "clean": "rimraf dist test/env/__tmp__",
    "extract": "sanity-tsdoc etl --outDir etc/api/@sanity/pkg-utils --tsconfig tsconfig.dist.json",
    "prepublishOnly": "pnpm run build",
    "pretest": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --build",
    "watch": "tsx scripts/watch.ts"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@microsoft/api-extractor": "^7.58.12",
    "@microsoft/tsdoc-config": "^0.18.1",
    "@optimize-lodash/rollup-plugin": "^6.0.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/parse-package-json": "workspace:^",
    "@typescript/typescript6": "^6.0.2",
    "@vanilla-extract/rollup-plugin": "^1.5.4",
    "browserslist": "^4.28.6",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "empathic": "^2.0.1",
    "esbuild": "^0.28.1",
    "find-config": "^1.0.0",
    "get-latest-version": "^6.0.1",
    "git-url-parse": "^16.1.0",
    "globby": "^16.2.2",
    "jsonc-parser": "^3.3.1",
    "lightningcss": "catalog:",
    "mkdirp": "^3.0.1",
    "outdent": "^0.8.0",
    "prettier": "^3.9.5",
    "pretty-bytes": "^7.1.1",
    "prompts": "^2.4.2",
    "rimraf": "^6.1.3",
    "rolldown": "1.2.0",
    "rolldown-plugin-dts": "0.27.13",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "rxjs": "^7.8.2",
    "treeify": "^1.1.0",
    "tsx": "^4.23.1",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@sanity/tsconfig": "workspace:^",
    "@types/babel__core": "^7.20.5",
    "@types/find-config": "^1.0.4",
    "@types/node": "catalog:",
    "@types/prompts": "^2.4.9",
    "@types/treeify": "^1.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "browserslist-to-esbuild": "2.1.1",
    "nanoexec": "^1.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "babel-plugin-react-compiler": "*",
    "typescript": "6.x || 7.x"
  },
  "peerDependenciesMeta": {
    "babel-plugin-react-compiler": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  }
}
