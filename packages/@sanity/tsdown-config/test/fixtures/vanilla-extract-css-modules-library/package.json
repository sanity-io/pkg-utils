{
  "name": "@fixtures/vanilla-extract-css-modules-library",
  "version": "0.0.0-development",
  "private": true,
  "license": "MIT",
  "sideEffects": [
    "*.css",
    "./dist/index.js"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./bundle.css": {
      "types": "./dist/bundle-css.d.ts",
      "browser": "./dist/bundle.css",
      "style": "./dist/bundle.css",
      "node": "./dist/bundle-css.js",
      "default": "./dist/bundle-css.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "@tsdown/css": "0.22.8",
    "@vanilla-extract/css": "^1.21.1"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./bundle.css": {
        "types": "./dist/bundle-css.d.ts",
        "browser": "./dist/bundle.css",
        "style": "./dist/bundle.css",
        "node": "./dist/bundle-css.js",
        "default": "./dist/bundle-css.js"
      },
      "./package.json": "./package.json"
    }
  }
}
